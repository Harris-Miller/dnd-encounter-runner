{
  "name": "dnd-encounter-runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node db/seeds/run.ts",
    "db:gen-types": "supabase gen types typescript --local > src/types/database.gen.ts",
    "parse:magic-items": "node scripts/parseMagicItems.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.35",
    "date-fns": "^4.1.0",
    "ramda": "^0.32.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "try": "^1.0.3",
    "ts-pattern": "^5.9.0",
    "ulid": "^3.0.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "1.0.0-beta.22",
    "drizzle-orm": "1.0.0-beta.22",
    "drizzle-seed": "1.0.0-beta.22",
    "eslint": "^9.39.4",
    "eslint-config-harris": "^5.1.2",
    "node-html-parser": "^7.1.0",
    "postgres": "^3.4.9",
    "supabase": "2.92.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
