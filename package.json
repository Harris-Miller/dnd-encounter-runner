{
  "name": "dnd-encounter-runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harrisjoseph/dnd-encounter-runner.git"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node db/seeds/run.ts",
    "db:gen-types": "supabase gen types typescript --local > src/types/database.gen.ts",
    "parse:magic-items": "node scripts/parseMagicItems.ts",
    "routes:gen": "tsr generate",
    "routes:watch": "tsr watch",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsc -b",
    "local-ci": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.13",
    "date-fns": "^4.4.0",
    "ramda": "^0.32.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "try": "^1.0.3",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/router-cli": "^1.167.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "drizzle-kit": "1.0.0-beta.22",
    "drizzle-orm": "1.0.0-beta.22",
    "drizzle-seed": "1.0.0-beta.22",
    "eslint": "^9.39.4",
    "eslint-config-harris": "6.0.0-beta.3",
    "node-html-parser": "^7.1.0",
    "postgres": "^3.4.9",
    "supabase": "2.92.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
